# Copy to .env and adjust as needed.  (.env is gitignored)
# PostGIS connection (matches docker-compose.yml)
PGHOST=localhost
PGPORT=5432
PGUSER=hex
PGPASSWORD=hex
PGDATABASE=hex

# SQLAlchemy / GeoAlchemy2 URL
DATABASE_URL=postgresql://hex:hex@localhost:5432/hex

# Projected CRS for all distance/area math (NAD83 Texas Centric Albers Equal Area)
PROJECTED_CRS=EPSG:3083
STORAGE_CRS=EPSG:4326
